FILE: social_network/post-module/src/main/resources/db/changelog/0010-reaction-guard.xml
SIZE: 2995 bytes
------------------------------------------
<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- 0010-01: чистим орфаны по POST -->
    <changeSet id="0010-01-delete-orphans-post" author="aslan">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="reaction"/>
            <tableExists tableName="post"/>
        </preConditions>
        <sql>
            DELETE FROM reaction r
            WHERE r.entity_type = 'POST'
              AND NOT EXISTS (SELECT 1 FROM post p WHERE p.id = r.entity_id);
        </sql>
    </changeSet>

    <!-- 0010-02: чистим орфаны по COMMENT -->
    <changeSet id="0010-02-delete-orphans-comment" author="aslan">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="reaction"/>
                <tableExists tableName="comment"/>
            </and>
        </preConditions>
        <sql>
            DELETE FROM reaction r
            WHERE r.entity_type = 'COMMENT'
              AND NOT EXISTS (SELECT 1 FROM comment c WHERE c.id = r.entity_id);
        </sql>
    </changeSet>

    <!-- 0010-03: функция проверки родителя -->
    <changeSet id="0010-03-create-fn-reaction-parent-exists" author="aslan" runOnChange="true">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="reaction"/>
        </preConditions>

        <!-- ВАЖНО: без разбиения, в CDATA -->
        <sql splitStatements="false" stripComments="false"><![CDATA[
            CREATE OR REPLACE FUNCTION reaction_parent_exists()
RETURNS trigger AS $$
            BEGIN
  IF NEW.entity_type = 'POST' THEN
    IF NOT EXISTS (SELECT 1 FROM post WHERE id = NEW.entity_id) THEN
      RAISE EXCEPTION 'Parent post % does not exist', NEW.entity_id;
            END IF;
  ELSIF NEW.entity_type = 'COMMENT' THEN
    IF NOT EXISTS (SELECT 1 FROM comment WHERE id = NEW.entity_id) THEN
      RAISE EXCEPTION 'Parent comment % does not exist', NEW.entity_id;
            END IF;
            END IF;
            RETURN NEW;
            END;
$$ LANGUAGE plpgsql;
            ]]></sql>
    </changeSet>

    <!-- 0010-04: триггер -->
    <changeSet id="0010-04-create-trg-reaction-parent-exists" author="aslan" runOnChange="true">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="reaction"/>
        </preConditions>
        <sql>
            DROP TRIGGER IF EXISTS trg_reaction_parent_exists ON reaction;
            CREATE TRIGGER trg_reaction_parent_exists
                BEFORE INSERT OR UPDATE ON reaction
                                     FOR EACH ROW EXECUTE FUNCTION reaction_parent_exists();
        </sql>
    </changeSet>

</databaseChangeLog>

