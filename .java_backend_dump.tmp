<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="0002-create-comments" author="aslan">
        <!-- Разрешаем старую checksum из логов -->
        <validCheckSum>9:1c47e53c9699cc1576409c404f13d2b0</validCheckSum>

        <!-- Убедимся, что таблица posts уже создана (из 0001) -->
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="posts"/>
        </preConditions>

        <createTable tableName="comment">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="post_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="parent_id" type="UUID"/>

            <column name="comment_text" type="TEXT">
                <constraints nullable="false"/>
            </column>

            <column name="is_blocked" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="like_amount" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="time" type="TIMESTAMPTZ" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="time_changed" type="TIMESTAMPTZ" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- FK на посты (таблица posts) -->
        <addForeignKeyConstraint
                baseTableName="comment"
                baseColumnNames="post_id"
                referencedTableName="posts"
                referencedColumnNames="id"
                constraintName="fk_comment_post"/>

        <!-- Необязательная self-FK для древовидных комментариев -->
        <addForeignKeyConstraint
                baseTableName="comment"
                baseColumnNames="parent_id"
                referencedTableName="comment"
                referencedColumnNames="id"
                constraintName="fk_comment_parent"
                deferrable="false"
                initiallyDeferred="false"/>

        <createIndex tableName="comment" indexName="idx_comment_post_id">
            <column name="post_id"/>
        </createIndex>

        <createIndex tableName="comment" indexName="idx_comment_parent_id">
            <column name="parent_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="comment" cascadeConstraints="true"/>
        </rollback>
    </changeSet>
</databaseChangeLog>

