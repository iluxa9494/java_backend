<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Удаляем ЛИШНЮЮ таблицу reactions, если есть -->
    <changeSet id="0009-drop-reactions" author="aslan">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="reactions"/>
        </preConditions>
        <dropTable tableName="reactions" cascadeConstraints="true"/>
    </changeSet>

    <!-- Пересоздаём правильную reaction -->
    <changeSet id="0009-recreate-reaction" author="aslan">
        <!-- Если структура неизвестна/битая — дропаем -->
        <preConditions onFail="CONTINUE">
            <tableExists tableName="reaction"/>
        </preConditions>
        <dropTable tableName="reaction" cascadeConstraints="true" />

        <createTable tableName="reaction">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="entity_type" type="varchar(16)">
                <constraints nullable="false"/>
            </column>

            <column name="entity_id" type="uuid">
                <constraints nullable="false"/>
            </column>

            <column name="user_id" type="uuid">
                <constraints nullable="false"/>
            </column>

            <column name="reaction_type" type="varchar(16)">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Уникальность реакции пользователя на сущность (POST/COMMENT + entity_id + user_id) -->
        <createIndex tableName="reaction" indexName="uk_reaction_entity_user" unique="true">
            <column name="entity_type"/>
            <column name="entity_id"/>
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>

